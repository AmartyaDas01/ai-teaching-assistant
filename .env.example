# ─── LLM (chat / quiz generation) ───────────────────────────────
# Provider is auto-selected: if OPENAI_API_KEY is set, OpenAI is used;
# otherwise the app falls back to Ollama (local). LLM_PROVIDER can force one.
LLM_PROVIDER=openai            # "openai" or "ollama"
OPENAI_API_KEY=               # leave blank to use local Ollama fallback
OPENAI_MODEL=gpt-4o
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
# Set to 0 to force CPU inference (workaround if Ollama's Metal/GPU backend
# crashes on older macOS). Leave blank/unset to use the GPU.
OLLAMA_NUM_GPU=

# ─── Embeddings (fixed: local, do not switch after ingesting) ────
# Local embeddings avoid ever re-indexing documents. all-MiniLM-L6-v2 = 384 dims.
EMBEDDING_PROVIDER=local       # "local" only for Phase 1
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Database ────────────────────────────────────────────────────
# SQLite for local dev. Swap to postgresql://user:pass@host:5432/db for prod.
DATABASE_URL=sqlite:///./app.db

# ─── ChromaDB (vector store) ─────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data

# ─── File storage ────────────────────────────────────────────────
STORAGE_PROVIDER=local         # "local" or "s3"
UPLOAD_DIR=./uploads

# ─── CORS ────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173
