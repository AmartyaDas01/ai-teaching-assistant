# ─── LLM (chat / quiz generation) ───────────────────────────────
# Provider is auto-selected: if OPENAI_API_KEY is set, OpenAI is used;
# otherwise the app falls back to Ollama (local). LLM_PROVIDER can force one.
LLM_PROVIDER=openai            # "openai" or "ollama"
OPENAI_API_KEY=               # leave blank to use local Ollama fallback
OPENAI_MODEL=gpt-4o
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
# Set to 0 to force CPU inference (workaround if Ollama's Metal/GPU backend
# crashes on older macOS). Leave blank/unset to use the GPU.
OLLAMA_NUM_GPU=

# ─── Embeddings (fixed per collection — don't switch after ingesting) ────
# "local"  = sentence-transformers, all-MiniLM-L6-v2 (384 dims), needs ~1GB RAM.
# "openai" = text-embedding-3-small (1536 dims) via API — no local model, so the
#            backend fits a free 512MB tier. Cost is negligible (~$0.02 / 1M tokens).
# The two produce different vector sizes, so changing this means re-uploading docs.
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Database ────────────────────────────────────────────────────
# SQLite for local dev. Swap to postgresql://user:pass@host:5432/db for prod.
DATABASE_URL=sqlite:///./app.db

# ─── Vector store ────────────────────────────────────────────────
# "chroma" = local, on-disk (fine for dev / hosts with a real disk).
# "qdrant" = remote; vectors survive restarts on hosts with no persistent disk
#            (e.g. free tiers, where Chroma's on-disk data would be wiped).
VECTOR_STORE=chroma

# Chroma (VECTOR_STORE=chroma)
CHROMA_PERSIST_DIR=./chroma_data

# Qdrant (VECTOR_STORE=qdrant). Get a free 1GB cluster at cloud.qdrant.io.
# Leave QDRANT_URL empty to use an in-memory client (nothing persists).
QDRANT_URL=
QDRANT_API_KEY=

# ─── File storage ────────────────────────────────────────────────
STORAGE_PROVIDER=local         # "local" or "s3"
UPLOAD_DIR=./uploads

# ─── CORS ────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173
